&config
! SPECTRE multi-volume guiding-center run on the committed two-volume tokamak
! fixture. Copy the fixture next to this input first:
!   cp test/tests/data/tok2vol.h5 tok2vol.h5
! then run ./build/simple.x simple_spectre.in. The reference behavior of this
! case is locked by test/tests/test_spectre_validation.py (loss accounting,
! Level-0 vs Level-1 fractions, trapped/passing split, determinism).
field_input = 'tok2vol.h5'   ! SPECTRE HDF5 equilibrium (VMEC-free)
integ_coords = 6             ! SPECTRE per-volume stacked-rho chart
integmode = 3                ! symplectic midpoint (per-volume Meiss canonical)
crossing_level = 1           ! interface crossing: 1 = Level-1 refraction map
trace_time = 1d-4            ! slowing-down trace time, s
sbeg = 0.5d0                 ! starting rho_g (SPECTRE radial label) for markers
ntestpart = 64               ! number of markers, area-weighted over the surface
ntimstep = 100               ! confined_fraction.dat time bins
npoiper2 = 256               ! integration steps per toroidal turn
facE_al = 4.0                ! 875 keV: guiding-center-defensible on tok2vol
relerr = 1d-11               ! integrator relative tolerance
deterministic = .True.       ! fixed seed for reproducible sampling
ran_seed = 12345
! Per-volume Meiss construction grid. spectre_ncon_phi = -1 (default) auto-clamps
! phi for axisymmetric fields (the tokamak memory saver); set r/th smaller for
! multi-volume cases, or spectre_ncon_phi = 32 to force the full phi resolution.
spectre_ncon_r = 48
spectre_ncon_th = 48
spectre_ncon_phi = -1
/
